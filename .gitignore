push_historic_data.py
migrate_pds.py

# Scratch / debug scripts — developer scratchpad, not project code
scratch/

# CI / runtime secrets
*.pem
*.key
secrets.json

# Next.js / Node
node_modules/
.next/
out/
build/
.DS_Store
*.log

# ML model training artifacts (keep pkl files tracked; exclude raw training CSVs)
training_data*.csv
raw_data*.csv
