# ─────────────────────────────────────────────
#  HD Dashboard — Environment Configuration
#  Copy this to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── TWILIO (WhatsApp) ──
# Sign up at twilio.com, enable WhatsApp sandbox
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Twilio WhatsApp sandbox number (or approved business number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── EMAIL (Gmail recommended) ──
# For Gmail: enable 2FA → generate App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# Ward report recipient (your email / department email)
DOCTOR_EMAIL=nephrologist@hospital.com

# ── CLINIC INFO ──
CLINIC_NAME=CH(SC) Nephrology
